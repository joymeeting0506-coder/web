---
const siteTitle = "我的个人站点"
const subtitle = "这是基于 Astro + GitHub Pages 搭建的个人页面"
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        background: #f5f7fa;
        color: #2c3e50;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
      }

      .card {
        background: #ffffff;
        padding: 60px 80px;
        border-radius: 16px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
        text-align: center;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        max-width: 600px;
        width: 100%;
      }

      .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
      }

      h1 {
        font-size: 32px;
        font-weight: 600;
        margin-bottom: 16px;
        color: #1a202c;
      }

      .subtitle {
        font-size: 16px;
        color: #64748b;
        line-height: 1.6;
        margin-bottom: 32px;
      }

      .divider {
        width: 60px;
        height: 3px;
        background: linear-gradient(90deg, #3b82f6, #8b5cf6);
        margin: 0 auto 32px;
        border-radius: 2px;
      }

      .links {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
      }

      .link-btn {
        padding: 10px 24px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        color: #3b82f6;
        text-decoration: none;
        font-size: 14px;
        transition: all 0.2s ease;
      }

      .link-btn:hover {
        background: #3b82f6;
        color: #fff;
        border-color: #3b82f6;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>{siteTitle}</h1>
      <div class="divider"></div>
      <p class="subtitle">{subtitle}</p>
      <div class="links">
        <a href="#" class="link-btn">首页</a>
        <a href="#" class="link-btn">关于我</a>
        <a href="#" class="link-btn">博客</a>
      </div>
    </div>
  </body>
</html>
