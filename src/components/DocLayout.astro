---
import Header from './Header.astro';
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | beau个人录</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: #333;
      line-height: 1.7;
      background: #ffffff;
    }
    .layout {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .main-container {
      display: flex;
      flex: 1;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      gap: 48px;
      padding: 32px 24px;
    }
    /* 左侧侧边栏 */
    .sidebar {
      width: 220px;
      flex-shrink: 0;
      position: sticky;
      top: 80px;
      height: fit-content;
      border-left: 2px solid #e2e8f0;
      padding-left: 16px;
    }
    .sidebar a {
      display: block;
      color: #64748b;
      text-decoration: none;
      padding: 6px 0;
      font-size: 15px;
      transition: color 0.2s;
    }
    .sidebar a:hover {
      color: #14b8a6;
    }
    /* 正文区 */
    .content {
      flex: 1;
      min-width: 0;
    }
    .content h1 {
      font-size: 32px;
      margin-bottom: 24px;
      color: #1e293b;
      font-weight: 500;
    }
    .content h2 {
      font-size: 24px;
      margin: 40px 0 16px;
      color: #1e293b;
      padding-bottom: 8px;
      border-bottom: 1px solid #f1f5f9;
      font-weight: 500;
    }
    .content p {
      margin-bottom: 16px;
      color: #475569;
    }
    .content blockquote {
      border-left: 4px solid #14b8a6;
      background: #f0fdfa;
      padding: 16px 20px;
      margin: 20px 0;
      border-radius: 4px;
      color: #0f766e;
    }
    .content ul, .content ol {
      margin: 16px 0 16px 24px;
    }
    .content li {
      margin-bottom: 8px;
      color: #475569;
    }
    @media (max-width: 768px) {
      .sidebar {
        display: none;
      }
    }
  </style>
</head>
<body>
  <div class="layout">
    <Header />
    <div class="main-container">
      <aside class="sidebar">
        <a href="#输出一些个人的想法与记录">输出一些个人的想法与记录</a>
      </aside>
      <main class="content">
        <slot />
      </main>
    </div>
  </div>
</body>
</html>
